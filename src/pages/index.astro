const skills = [
  { name: 'Java', icon: Code },
  { name: 'Python', icon: Code },
  { name: '.NET', icon: Braces },
  { name: 'Angular', icon: Wind },
  { name: 'Spring Boot', icon: Server },
  { name: 'Symfony', icon: Bot },
  { name: 'HTML / CSS / PHP', icon: Wind },
  { name: 'MySQL', icon: Database },
  { name: 'PostgreSQL', icon: Database },
