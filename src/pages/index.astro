    location: 'Megrine, Tunisia',
    period: 'Feb 2024 - May 2024',
    summary:
      'Contributed to broadband integration activities and Wi-Fi testing automation in a telecom software context.',
    responsibilities: [
      'Worked on Wi-Fi test automation workflows with Broadfarm.',
      'Participated in broadband solution configuration and integration tasks.',
      'Collaborated with software teams on implementation of new features.',
      'Prepared and presented weekly technical reports to the supervision team.',
      'Supported optimization of integration processes for network solutions.'
    ],
    skills: ['Broadfarm', 'Network Integration', 'Testing', 'Reporting']
  },
  {
    id: 'tunisie-telecom',
    title: 'Telecom Intern',
    company: 'Tunisie Telecom',
    location: 'Tunis, Tunisia',
    period: 'Jul 2023 - Jul 2023',
    summary:
      'Supported local telecom network analysis and daily operational reliability activities.',
    responsibilities: [
      'Participated in local telecom network analysis and identification of improvement points.',
      'Assisted incident follow-up and preventive maintenance operations.',
      'Produced daily status reports on network health.',
      'Contributed to optimization of troubleshooting procedures.'
    ],
    skills: ['Telecom Operations', 'Incident Management', 'Network Analysis']
  }
];

const projects = [
  {
    id: 'private-cloud-platform',
    title: 'Automated Private Cloud Infrastructure',
    description:
      'Designed and automated a private cloud stack with OpenStack, Ansible, and Kubernetes, including monitoring and anomaly detection components.',
    technologies: ['OpenStack', 'Ansible', 'Kubernetes', 'Prometheus', 'Grafana', 'Alertmanager', 'Random Forest'],
    status: 'Completed',
    year: '2025'
  },
  {
