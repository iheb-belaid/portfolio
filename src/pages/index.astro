---
import MainLayout from '../layout/MainLayout.astro';
import { Image } from 'astro:assets';
import profileImage from '../assets/images/iheb.png';
import {
  GraduationCap,
  Award,
  Code,
  Database,
  Cloud,
  ShieldCheck,
  Settings,
  TerminalSquare,
  Wind,
  Bot,
  GitMerge,
  Braces,
  Server,
  BrainCircuit,
  Link as LinkIcon,
  ExternalLink,
  Folder
} from 'lucide-astro';

const profile = {
  name: 'Iheb Belaid',
  role: 'Cloud & DevOps Engineering Student',
  summary:
    'Cloud and DevOps engineering student with hands-on internship experience in CI/CD, automation, containerization, and telecom environments. I build reliable full-stack and infrastructure solutions with a strong focus on deployment quality, observability, and continuous improvement.',
  email: 'ihebbelaid3@gmail.com',
  phone: '+21653122809',
  location: 'Tunis, Tunisia',
  linkedin: 'https://www.linkedin.com/in/iheb-bela%C3%AFd/',
  github: 'https://github.com/iheb-belaid',
  resumePath: '/iheb-belaid-cv.pdf'
};

const contactLinks = [
  {
    href: `mailto:${profile.email}`,
    label: 'Email',
    svgPath: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z',
