    status: 'Completed',
    year: '2024'
  },
  {
    id: 'ehealth-desktop',
    title: 'E-Health Desktop Application',
    description:
      'Desktop application developed with JavaFX for patient record management and healthcare workflow support.',
    technologies: ['JavaFX', 'Java', 'Desktop'],
    status: 'Completed',
    year: '2023'
  },
  {
    id: 'koultime-mobile',
